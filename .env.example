# 丸子的工作台 — 环境变量配置示例
# 复制此文件为 .env 并填写真实值
# 注意：.env 文件包含密钥，不要提交到 Git

# 豆包大模型（火山方舟 ARK）
ARK_API_KEY=你的API_Key
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_TEXT_MODEL=你的文本模型ID或推理接入点ID
ARK_VISION_MODEL=你的视觉模型ID或推理接入点ID

# DeepSeek（可选，备用）
OPENAI_API_KEY=
OPENAI_API_BASE=https://api.deepseek.com

# 服务端口
PORT=5200
